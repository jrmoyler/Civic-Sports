# Civic Sports Consulting — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# Base URL (used for canonical links and OG tags in any server-rendered config)
VITE_SITE_URL=https://civicsports.com

# Contact form endpoint (e.g. Formspree, Netlify Forms, or your own API)
# VITE_CONTACT_API_URL=https://formspree.io/f/YOUR_FORM_ID

# Analytics (optional)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
